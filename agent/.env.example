# ============================================================
# AdsClaw Agent - Variaveis de Ambiente
# Referencia: references/PLAN.md §5
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Supabase (OBRIGATORIO)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Gemini (OBRIGATORIO)
GEMINI_API_KEY=

# Telegram (OBRIGATORIO)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# UUID de um cliente quando nenhum registro em clients.telegram_chat_ids contém o chat (opcional, dev)
TELEGRAM_DEFAULT_CLIENT_ID=

# Servidor
HTTP_PORT=3001
COCKPIT_URL=http://localhost:5173

# Agent Config
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=30
ACTIVE_PROVIDER=gemini
LOG_LEVEL=info

# Integracoes (Opcionais no MVP)
APIFY_TOKEN=
META_ACCESS_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# Criptografia de credenciais per-client (obrigatorio em producao)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=
