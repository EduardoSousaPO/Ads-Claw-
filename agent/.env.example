# ==========================================
# GESTÃO SEGURA DO AMBIENTE LOCAL - AdsClaw 
# ==========================================

# 1. Configurações do Supabase
# Crie seu projeto em app.supabase.com e vá em "Project Settings -> API"
SUPABASE_URL=https://[sua-referencia-aqui].supabase.co
# Use o SERVICE_ROLE secret! (Atenção: Não vaze isso pro client side frontend Web!)
SUPABASE_SERVICE_KEY=eyJhbG...

# 2. Configurações de Inteligência (Local Ecosystem)
# Crie em https://aistudio.google.com/
GEMINI_API_KEY=

# 3. Cockpit Interativo - Telegram Integrator
# Fale com o @BotFather no Telegram pra gerar um novo token para o AdsClaw
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=
